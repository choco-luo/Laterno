---
const links = [
  { name: "日誌", path: "/" },
  { name: "關於我", path: "/about" },
  { name: "攝影作品", path: "/gallery" },
  { name: "Abyss島嶼(施工中)", path: "/abyss" },
  { name: "聯絡", path: "/contact" }
];

const marqueeItems = [
  "Welcome to Choco卷可餅的海洋日誌",
  "每週更新：生活筆記、攝影作品、開發實驗",
  "Abyss 島嶼企劃施工中，敬請期待"
];
---

<header id="main-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-white/90 backdrop-blur-md shadow-sm py-3">
  <div class="container mx-auto px-6 max-w-6xl flex justify-between items-center">
    <a href="/" id="logo-link" class="text-xl font-bold tracking-wider uppercase flex items-center gap-2 text-slate-800">
      <span id="logo-icon">🐳</span>
      海洋部落格 | 座頭鯨
    </a>
    
    <div class="hidden md:flex items-center space-x-8">
      {
        links.map((item) => (
          <a 
            href={item.path} 
            class="nav-link text-sm font-medium hover:text-cyan-500 transition-colors text-slate-600"
          >
            {item.name}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-4">
       <button id="search-btn" class="hidden md:block p-2 transition-colors text-slate-600 hover:bg-slate-100 rounded-full">
         <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-search"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
       </button>
       <button id="mobile-menu-btn" class="md:hidden text-slate-800">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-menu"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      </button>
    </div>
  </div>

  <div class="marquee-wrap border-t border-slate-200/80 bg-gradient-to-r from-cyan-50 via-white to-cyan-50">
    <div class="marquee-track" aria-label="網站公告跑馬燈">
      <span class="marquee-content">
        {marqueeItems.join("  ✦  ")}  ✦  {marqueeItems.join("  ✦  ")}
      </span>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 right-0 bg-white border-b border-slate-100 p-4 shadow-lg">
    <div class="flex flex-col space-y-4">
      {
        links.map((item) => (
          <a 
            href={item.path} 
            class="text-slate-600 font-medium hover:text-cyan-600"
          >
            {item.name}
          </a>
        ))
      }
    </div>
  </div>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  // Mobile Menu Toggle
  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  const particleColors = ['#22d3ee', '#0ea5e9', '#38bdf8', '#67e8f9', '#f8fafc'];
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  const spawnSquareBurst = (event) => {
    if (prefersReducedMotion.matches) return;

    if (event.pointerType === 'mouse' && event.button !== 0) return;

    const particleCount = 12;
    const fragment = document.createDocumentFragment();

    for (let i = 0; i < particleCount; i += 1) {
      const square = document.createElement('span');
      const angle = (Math.PI * 2 * i) / particleCount + Math.random() * 0.4;
      const distance = 24 + Math.random() * 50;
      const size = 6 + Math.random() * 8;
      const rotation = Math.floor(Math.random() * 220) - 110;

      square.className = 'click-burst-square';
      square.style.left = `${event.clientX}px`;
      square.style.top = `${event.clientY}px`;
      square.style.width = `${size}px`;
      square.style.height = `${size}px`;
      square.style.backgroundColor = particleColors[i % particleColors.length];
      square.style.setProperty('--dx', `${Math.cos(angle) * distance}px`);
      square.style.setProperty('--dy', `${Math.sin(angle) * distance}px`);
      square.style.setProperty('--dr', `${rotation}deg`);

      square.addEventListener('animationend', () => square.remove(), { once: true });
      fragment.appendChild(square);
    }

    document.body.appendChild(fragment);
  };

  window.addEventListener('pointerdown', spawnSquareBurst);
</script>

<style>
  .marquee-wrap {
    overflow: hidden;
    white-space: nowrap;
  }

  .marquee-track {
    display: flex;
    align-items: center;
    min-height: 2.25rem;
  }

  .marquee-content {
    display: inline-block;
    padding-left: 100%;
    color: rgb(15 23 42);
    font-size: 0.875rem;
    letter-spacing: 0.02em;
    animation: marquee-scroll 20s linear infinite;
  }

  @keyframes marquee-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-100%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-content {
      animation: none;
      padding-left: 0.75rem;
    }
  }
</style>
